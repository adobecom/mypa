# OAuth credentials — copy this file to .env and fill in your own values.
# Register OAuth apps at the URLs listed in src/shared/oauth-config.ts.
# In CI/GitHub Actions, set these as repository secrets instead.

GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET is not needed — the app uses Device Flow

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
