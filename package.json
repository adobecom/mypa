{
  "name": "mypa",
  "version": "0.1.0",
  "description": "Local-first personal assistant for developers",
  "main": "out/main/index.js",
  "homepage": "https://adobecom.github.io/mypa/",
  "repository": {
    "type": "git",
    "url": "https://github.com/adobecom/mypa.git"
  },
  "bugs": {
    "url": "https://github.com/adobecom/mypa/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.17.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.mypa.app",
    "productName": "mypa",
    "protocols": [
      {
        "name": "mypa",
        "schemes": [
          "mypa"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/onnxruntime-node/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "adobecom",
        "repo": "mypa"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        { "target": "dmg" },
        { "target": "zip" }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
